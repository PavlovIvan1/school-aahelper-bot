BOT_TOKEN=your_bot_token_here
# Прокси для Telegram. Поддерживаются http:// и socks5:// (для socks нужен пакет aiohttp-socks — он в requirements.txt)
TELEGRAM_PROXY_URL=socks5://user:pass@proxy-host:8000
SUPPORT_CALL_FORM_URL=https://forms.amocrm.ru/rzlwvrl
OMNIDESK_WEBHOOK_URL=https://telegramwh.omnidesk.ru/webhooks/telegram/13619/2ad59c852bbdcf83

# Telegram ID администраторов через запятую — им доступна команда /admin и мини-апп рассылок
ADMIN_IDS=123456789,987654321
# Публичный HTTPS-адрес мини-аппа (например, адрес cloudflared tunnel).
# Бот отдаёт и API, и статику мини-аппа сам — заполняется/обновляется автоматически через run.sh.
ADMIN_WEBAPP_URL=
# На каком порту бот отдаёт HTTP API + мини-апп админ-панели
WEBAPP_API_HOST=0.0.0.0
WEBAPP_API_PORT=8080